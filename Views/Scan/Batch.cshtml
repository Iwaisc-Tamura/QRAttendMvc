@using QRAttendMvc.Models
@{
    Layout = null;

    string kind = ViewBag.Kind as string ?? "IN";
    string modeLabel = kind == "IN" ? "入場" : "退場";
    string title = "入退場登録（一括）";
    string kaisaiCd = ViewBag.CurrentKaisaiCd as string ?? "";
    string login = ViewBag.LoginDisplay as string ?? "XXXXXX";
    var ev = ViewBag.Event as Gt01KaisaiEvent;

    string FmtYmd(string? ymd)
    {
        if (string.IsNullOrWhiteSpace(ymd)) return "";
        return ymd.Replace("-", "/");
    }

    string FmtHm(string? hhmm)
    {
        if (string.IsNullOrWhiteSpace(hhmm)) return "";
        var s = hhmm.Trim().PadLeft(4, '0');
        return s.Substring(0, 2) + ":" + s.Substring(2, 2);
    }
}

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 協力会社入退場記録システム</title>

    <link rel="stylesheet" href="~/css/scan-result.css" />
    <link rel="stylesheet" href="~/css/entryexit-batch.css" />

    <style>
        /* スキャナ入力を画面から隠すがフォーカス可能にする */
        .visually-hidden-input {
            position: absolute;
            left: -9999px;
            top: auto;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        /* （案内要素を削除したため追加スタイルは不要） */
    </style>
</head>

<body class="event-page">
    <div class="ee-header">
        <div class="ev-tab @(kind == "IN" ? "ev-mode-in" : "ev-mode-out")">@modeLabel</div>
        <div class="ev-title">@title</div>
    </div>

    <div class="card ee-card">
        @if (string.IsNullOrEmpty(kaisaiCd) || ev == null)
        {
            <div class="alert alert-warning">
                イベントが確定していません。先に「イベント選択」で確定してください。
            </div>
        }
        else
        {
            <div class="ee-top">
                <div class="ee-event">
                    <div class="ee-row"><div class="ee-k">イベント開催日</div><div class="ee-v">@FmtYmd(ev.KaisaiYmd)</div></div>
                    <div class="ee-row"><div class="ee-k">区分</div><div class="ee-v">@($"{ev.EventCd} {ev.EventName}")</div></div>
                    <div class="ee-row"><div class="ee-k">開催拠点</div><div class="ee-v">@($"{ev.BranchCd} {ev.BranchName}")</div></div>
                    <div class="ee-row"><div class="ee-k">受講場所</div><div class="ee-v">@ev.Location</div></div>
                    <div class="ee-row ee-row-inline">
                        <div class="ee-k">開催時刻</div>
                        <div class="ee-v">@($"{FmtHm(ev.StartTime)} ～ {FmtHm(ev.EndTime)}")</div>
                        <div class="ee-k ee-k-small">受付開始時刻</div>
                        <div class="ee-v ee-v-small">@FmtHm(ev.ReceptTime)</div>
                        <div class="ee-now-label">現在時刻</div>
                        <div id="layoutTime" class="ee-now-time"></div>
                    </div>
                </div>

                <div class="ee-side">
                    <div class="ee-login" aria-label="ログイン情報">
                        <div class="ev-login-row">
                            <span class="ev-login-label">ログイン</span>
                            <span class="ev-login-value">@login</span>
                        </div>
                        <div class="ev-login-row">
                            <span class="ev-login-label">日付</span>
                            <span class="ev-login-value">@DateTime.Now.ToString("yyyy/MM/dd")</span>
                        </div>
                        <div class="ev-login-row">
                            <span class="ev-login-label">時刻</span>
                            <span class="ev-login-value">@DateTime.Now.ToString("HH:mm:ss")</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="ee-read">
            <div class="ee-icon-wrap">
                <img id="resultIcon" class="result-icon" src="/images/Circle.png" alt="結果" style="visibility:hidden;" />
            </div>

            <div class="ee-read-text">
                <div class="ee-code" id="lastCode">－</div>
                <div class="ee-name-row">
                    <span id="lastName">－</span>
                    <span id="lastTime" class="ee-read-time"></span>
                </div>
            </div>
        </div>

        <div class="ee-input">
            <!-- 実際の入力は画面外に置きフォーカスを常に維持する -->
            <input id="scanInput" class="visually-hidden-input"
                   autocomplete="off" autocorrect="off" spellcheck="false" inputmode="numeric" />
        </div>

        <hr />
        <div class="ee-section-title">記録結果</div>
        <div class="ee-log-box">
            <textarea id="logArea" class="form-control ee-log" rows="6" readonly></textarea>
        </div>

        <div class="ee-footer">
            <button id="btnRelease" class="btn btn-warning ee-btn ee-btn-release" disabled>解除</button>

            <form asp-action="BackToEventSelection" method="post" style="display:inline;">
                <input type="hidden" name="kind" value="@kind" />
                <button type="submit" class="btn ee-btn btn-primary ee-btn-back">
                    イベント選択画面に戻る
                </button>
            </form>
        </div>
    </div>

<script>
    const input = document.getElementById("scanInput");
    const logArea = document.getElementById("logArea");
    const lastCode = document.getElementById("lastCode");
    const lastName = document.getElementById("lastName");
    const lastTime = document.getElementById("lastTime");
    const resultIcon = document.getElementById("resultIcon");
    const btnRelease = document.getElementById("btnRelease");

    const kind = "@kind";
    let locked = false;
    let buzzerCtx = null;
    let buzzerOsc = null;
    let buzzerGain = null;

    function appendLog(line) {
        const prev = logArea.value || "";
        logArea.value = (line + "\n" + prev).trimEnd();
    }

    function setIcon(result) {
        let src = "";
        let alt = "";

        if (result === "OK") {
            src = "@Url.Content("~/images/Circle.png")";
            alt = "正常";
        } else if (result === "WARN") {
            src = "@Url.Content("~/images/Triangle.png")";
            alt = "警告";
        } else if (result === "NG") {
            src = "@Url.Content("~/images/Cross.png")";
            alt = "エラー";
        }

        resultIcon.src = src;
        resultIcon.alt = alt;
        resultIcon.style.visibility = "visible";
        resultIcon.classList.remove("pop-animate");
        void resultIcon.offsetWidth;
        resultIcon.classList.add("pop-animate");
    }

    function showReadResult(code, name, timeText) {
        lastCode.textContent = code || "－";
        lastName.textContent = name || "－";
        lastTime.textContent = timeText || "";
    }

    function playBeep(result) {
        try {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;

            const ctx = new AudioCtx();
            if (ctx.state === "suspended") ctx.resume();

            const osc = ctx.createOscillator();
            const gain = ctx.createGain();

            const freq = result === "OK" ? 880 : result === "WARN" ? 660 : 220;
            osc.type = "sine";
            osc.frequency.value = freq;

            const t0 = ctx.currentTime;
            gain.gain.setValueAtTime(0.0001, t0);
            gain.gain.exponentialRampToValueAtTime(0.18, t0 + 0.01);
            gain.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.12);

            osc.connect(gain);
            gain.connect(ctx.destination);

            osc.start(t0);
            osc.stop(t0 + 0.13);
            osc.onended = () => {
                try { ctx.close(); } catch (e) {}
            };
        } catch (e) {}
    }

    function startBuzzer() {
        try {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;
            if (!buzzerCtx) buzzerCtx = new AudioCtx();
            if (buzzerCtx.state === "suspended") buzzerCtx.resume();
            if (buzzerOsc) return;

            buzzerOsc = buzzerCtx.createOscillator();
            buzzerGain = buzzerCtx.createGain();

            buzzerOsc.type = "square";
            buzzerOsc.frequency.value = 880;
            buzzerGain.gain.value = 0.08;

            buzzerOsc.connect(buzzerGain);
            buzzerGain.connect(buzzerCtx.destination);
            buzzerOsc.start();
        } catch (e) {}
    }

    function stopBuzzer() {
        try {
            if (buzzerOsc) {
                buzzerOsc.stop();
                buzzerOsc.disconnect();
                buzzerOsc = null;
            }

            if (buzzerGain) {
                buzzerGain.disconnect();
                buzzerGain = null;
            }
        } catch (e) {}
    }

    function lockReading() {
        locked = true;
        input.disabled = true;
        btnRelease.disabled = false;
        startBuzzer();
    }

    function unlockReading() {
        stopBuzzer();
        locked = false;
        input.disabled = false;
        btnRelease.disabled = true;
        input.value = "";
        try { input.focus(); } catch (e) {}
    }

    btnRelease.addEventListener("click", unlockReading);

    // 常にスキャナ入力にフォーカスを当てる（ユーザ要望）
    window.addEventListener("load", () => {
        try { input.focus(); } catch (e) {}

        // フォーカスが外れたら自動で戻す（ロック中は除外）
        input.addEventListener("blur", () => {
            if (!locked) {
                setTimeout(() => {
                    try { input.focus(); } catch (e) {}
                }, 50);
            }
        });

        // タブ切替やウィンドウ復帰時にフォーカスを戻す
        document.addEventListener("visibilitychange", () => {
            if (!document.hidden && !locked) {
                try { input.focus(); } catch (e) {}
            }
        });
        window.addEventListener("focus", () => {
            if (!locked) {
                try { input.focus(); } catch (e) {}
            }
        });

        // 端末によってはフォーカスが奪われるため定期的にフォーカスを戻す（負荷低め）
        const focusKeeper = setInterval(() => {
            if (!locked && document.hasFocus()) {
                try { input.focus(); } catch (e) {}
            }
        }, 2000);

        window.addEventListener("beforeunload", () => clearInterval(focusKeeper));
    });

    function parseQrString(raw) {
        // 期待フォーマット:
        // 通常: "1,1234567890"
        // 仮:   "2,1234567890,1234"
        if (!raw) return { worker: "", overrideKaisai: null, original: raw };
        const s = raw.trim();
        const parts = s.split(",").map(p => p.trim());
        if (parts.length >= 2 && (parts[0] === "1" || parts[0] === "2")) {
            const worker = parts[1] || "";
            const override = parts[0] === "2" && parts.length >= 3 ? parts[2] || null : null;
            return { worker: worker, overrideKaisai: override, original: s, type: parts[0] };
        }
        // フォールバック: 10桁の生IDだけが渡される場合など
        return { worker: s, overrideKaisai: null, original: s, type: null };
    }

    input.addEventListener("keydown", async (e) => {
        if (e.key !== "Enter") return;

        const raw = (input.value || "").trim();
        input.value = "";

        if (!raw || locked) return;

        const parsed = parseQrString(raw);

        // クライアント側で仮QRを入場で使用しようとした場合は即時NG表示（サーバ側でも必ず検証します）
        if (parsed.type === "2" && (kind || "").toUpperCase() === "IN") {
            setIcon("NG");
            playBeep("NG");
            appendLog(`${parsed.original} 仮QRは入場では使用できません`);
            showReadResult(parsed.worker || parsed.original, "仮QRは入場不可", "");
            lockReading();
            return;
        }

        const workerCd = parsed.worker;
        const overrideKaisai = parsed.overrideKaisai;

        // 重要: プレフィックス (1/2) が付いている場合は元の文字列をそのまま送る（サーバ側で検証）
        const payloadCode = (parsed.type === "1" || parsed.type === "2") ? parsed.original : workerCd;

        const payload = {
            code: payloadCode,
            kind: kind,
            kaisaiCd: overrideKaisai || "@kaisaiCd"
        };

        const res = await fetch('@Url.Action("Record", "Scan")', {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        const data = await res.json();
        const t = data.time ? data.time.slice(0, 2) + ":" + data.time.slice(2, 4) : "";

        showReadResult(data.code || workerCd || raw, data.name || (data.result === "NG" ? data.message : "－"), t);

        if (data.result === "OK") {
            setIcon("OK");
            playBeep("OK");
            appendLog(`${data.code} ${data.name ?? ""} ${t} ${data.message}`);
            try { input.focus(); } catch (e) {}
            return;
        }

        if (data.result === "WARN") {
            setIcon("WARN");
            playBeep("WARN");
            appendLog(`${data.code ?? workerCd} ${data.name ?? ""} ${t} ${data.message}`);
            lockReading();
            return;
        }

        setIcon("NG");
        playBeep("NG");
        appendLog(`${data.code ?? workerCd} ${t} ${data.message}`);
        lockReading();
    });

    function updateLayoutClock() {
        const d = new Date();
        const pad = (n) => String(n).padStart(2, "0");
        const time = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;


        const elTime = document.getElementById("layoutTime");
        if (elTime) elTime.textContent = time;

    }

    updateLayoutClock();
    setInterval(updateLayoutClock, 1000);
</script>
</body>
</html>
