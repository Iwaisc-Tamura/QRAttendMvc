@using QRAttendMvc.Models
@{
    Layout = null;

    string kind = ViewBag.Kind as string ?? "IN";
    string modeLabel = kind == "IN" ? "入場" : "退場";
    string title = "入退場登録（臨時対応）";
    string kaisaiCd = ViewBag.CurrentKaisaiCd as string ?? "";
    string login = ViewBag.LoginDisplay as string ?? "XXXXXX";
    var ev = ViewBag.Event as Gt01KaisaiEvent;

    ViewData["Title"] = title;

    string FmtYmd(string? ymd)
    {
        if (string.IsNullOrWhiteSpace(ymd)) return "";
        return ymd.Replace("-", "/");
    }

    string FmtHm(string? hhmm)
    {
        if (string.IsNullOrWhiteSpace(hhmm)) return "";
        var s = hhmm.Trim().PadLeft(4, '0');
        return s.Substring(0, 2) + ":" + s.Substring(2, 2);
    }
}

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 協力会社入退場記録システム</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/scan-result.css" />
    <link rel="stylesheet" href="~/css/entryexit-batch.css" />
</head>

<body class="event-page">
    <div class="ee-header">
        <div class="ev-tab @(kind == "IN" ? "ev-mode-in" : "ev-mode-out")">@modeLabel</div>
        <div class="ev-title">@title</div>
    </div>

    <div class="card ee-card">
        @if (string.IsNullOrEmpty(kaisaiCd) || ev == null)
        {
            <div class="alert alert-warning">
                イベントが確定していません。先に「イベント選択」で確定してください。
            </div>
        }
        else
        {
            <div class="ee-top">
                <div class="ee-event">
                    <div class="ee-row"><div class="ee-k">イベント開催日</div><div class="ee-v">@FmtYmd(ev.KaisaiYmd)</div></div>
                    <div class="ee-row"><div class="ee-k">区分</div><div class="ee-v">@($"{ev.EventCd} {ev.EventName}")</div></div>
                    <div class="ee-row"><div class="ee-k">開催拠点</div><div class="ee-v">@($"{ev.BranchCd} {ev.BranchName}")</div></div>
                    <div class="ee-row"><div class="ee-k">受講場所</div><div class="ee-v">@ev.Location</div></div>
                    <div class="ee-row ee-row-inline">
                        <div class="ee-k">開催時刻</div>
                        <div class="ee-v">@($"{FmtHm(ev.StartTime)} ～ {FmtHm(ev.EndTime)}")</div>
                        <div class="ee-k ee-k-small">受付開始時刻</div>
                        <div class="ee-v ee-v-small">@FmtHm(ev.ReceptTime)</div>
                    </div>
                </div>

                <div class="ee-side">
                    <div class="ee-login" aria-label="ログイン情報">
                        <div class="ev-login-row">
                            <span class="ev-login-label">ログイン</span>
                            <span class="ev-login-value">@login</span>
                        </div>
                        <div class="ev-login-row">
                            <span class="ev-login-label">日付</span>
                            <span class="ev-login-value">@DateTime.Now.ToString("yyyy/MM/dd")</span>
                        </div>
                        <div class="ev-login-row">
                            <span class="ev-login-label">時刻</span>
                            <span class="ev-login-value">@DateTime.Now.ToString("HH:mm:ss")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- QRスキャナ入力（Batch と同様の領域） -->
            <div class="ee-input">
                <div class="ee-section-title">QRスキャナからの入力</div>
                <input id="qrScanInput" class="form-control form-control-lg"
                       placeholder="ここにカーソルを置いたままQRを読み取ります" />
            </div>

            <div class="ee-section-title">臨時入力</div>
            <div class="ee-temp-form">
                <div class="ee-temp-grid">
                    <div class="ee-temp-field">
                        <label class="form-label" for="scanInput">作業員ID</label>
                        <input id="scanInput" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="companyCd">協力会社コード</label>
                        <input id="companyCd" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="companyKana">会社名カナ</label>
                        <input id="companyKana" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="companyName">会社名</label>
                        <input id="companyName" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="workerKana">作業員名カナ</label>
                        <input id="workerKana" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="workerName">作業員名</label>
                        <input id="workerName" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="birthDate">生年月日</label>
                        <input id="birthDate" type="date" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="excludeDate">名簿対象除外日</label>
                        <input id="excludeDate" type="date" class="form-control" />
                    </div>
                    <div class="ee-temp-field">
                        <label class="form-label" for="entryRecord">入場記録</label>
                        <input id="entryRecord" class="form-control" />
                    </div>
                    <div class="ee-temp-field ee-temp-field-wide">
                        <label class="form-label" for="reason">事由</label>
                        <input id="reason" class="form-control" />
                    </div>
                </div>
                <div class="ee-temp-actions">
                    <button id="btnTempRegister" class="btn btn-primary ee-btn ee-btn-back" type="button">登録</button>
                </div>
            </div>

            <div class="ee-section-title">読み取り結果</div>
            <div class="ee-read">
                <div class="ee-icon-wrap">
                    <img id="resultIcon" class="result-icon" src="/images/Circle.png" alt="結果" style="visibility:hidden;" />
                </div>

                <div class="ee-read-text">
                    <div class="ee-code" id="lastCode">－</div>
                    <div class="ee-name-row">
                        <span id="lastName">－</span>
                        <span id="lastTime" class="ee-read-time"></span>
                    </div>
                </div>
            </div>

            <div class="ee-section-title">記録結果</div>
            <div class="ee-log-box">
                <textarea id="logArea" class="form-control ee-log" rows="6" readonly></textarea>
            </div>
        }
        <div class="ee-footer">
            <button id="btnRelease" class="btn btn-warning ee-btn ee-btn-release" disabled>解除</button>
            <a asp-controller="EventSelection" asp-action="Index" class="btn ee-btn btn-primary ee-btn-back">
                イベント選択画面に戻る
            </a>
        </div>
    </div>

<script>
    const qrInput = document.getElementById("qrScanInput");
    const input = document.getElementById("scanInput"); // 作業員ID表示欄
    const companyCdEl = document.getElementById("companyCd");
    const companyKanaEl = document.getElementById("companyKana");
    const companyNameEl = document.getElementById("companyName");
    const workerKanaEl = document.getElementById("workerKana");
    const workerNameEl = document.getElementById("workerName");
    const birthDateEl = document.getElementById("birthDate");

    const logArea = document.getElementById("logArea");
    const lastCode = document.getElementById("lastCode");
    const lastName = document.getElementById("lastName");
    const lastTime = document.getElementById("lastTime");
    const resultIcon = document.getElementById("resultIcon");
    const btnRelease = document.getElementById("btnRelease");

    const kind = "@kind";
    const kaisaiCd = "@kaisaiCd";
    let locked = false;
    let buzzerCtx = null;
    let buzzerOsc = null;
    let buzzerGain = null;

    function appendLog(line) {
        if (!logArea) return;
        const prev = logArea.value || "";
        logArea.value = (line + "\n" + prev).trimEnd();
    }

    function setIcon(result) {
        if (!resultIcon) return;
        let src = "";
        let alt = "";
        if (result === "OK") { src = "/images/Circle.png"; alt = "正常"; }
        else if (result === "WARN") { src = "/images/Triangle.png"; alt = "警告"; }
        else if (result === "NG") { src = "/images/Cross.png"; alt = "エラー"; }

        resultIcon.src = src;
        resultIcon.alt = alt;
        resultIcon.style.visibility = "visible";
        resultIcon.classList.remove("pop-animate");
        void resultIcon.offsetWidth;
        resultIcon.classList.add("pop-animate");
    }

    function showReadResult(code, name, timeText) {
        if (lastCode) lastCode.textContent = code || "－";
        if (lastName) lastName.textContent = name || "－";
        if (lastTime) lastTime.textContent = timeText || "";
    }

    function playBeep(result) {
        try {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;
            const ctx = new AudioCtx();
            if (ctx.state === "suspended") ctx.resume();

            const osc = ctx.createOscillator();
            const gain = ctx.createGain();

            const freq = result === "OK" ? 880 : result === "WARN" ? 660 : 220;
            osc.type = "sine";
            osc.frequency.value = freq;

            const t0 = ctx.currentTime;
            gain.gain.setValueAtTime(0.0001, t0);
            gain.gain.exponentialRampToValueAtTime(0.18, t0 + 0.01);
            gain.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.12);

            osc.connect(gain);
            gain.connect(ctx.destination);

            osc.start(t0);
            osc.stop(t0 + 0.13);
            osc.onended = () => { try { ctx.close(); } catch (e) {} };
        } catch (e) {}
    }

    // ブザー（解除まで鳴り続け）
    function startBuzzer() {
        try {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;
            if (!buzzerCtx) buzzerCtx = new AudioCtx();
            if (buzzerCtx.state === "suspended") buzzerCtx.resume();
            if (buzzerOsc) return;

            buzzerOsc = buzzerCtx.createOscillator();
            buzzerGain = buzzerCtx.createGain();

            buzzerOsc.type = "square";
            buzzerOsc.frequency.value = 880;
            buzzerGain.gain.value = 0.08;

            buzzerOsc.connect(buzzerGain);
            buzzerGain.connect(buzzerCtx.destination);
            buzzerOsc.start();
        } catch (e) {}
    }

    function stopBuzzer() {
        try {
            if (buzzerOsc) {
                buzzerOsc.stop();
                buzzerOsc.disconnect();
                buzzerOsc = null;
            }
            if (buzzerGain) {
                buzzerGain.disconnect();
                buzzerGain = null;
            }
        } catch (e) {}
    }

    function lockReading() {
        locked = true;
        if (qrInput) qrInput.disabled = true;
        if (input) input.disabled = true;
        if (btnRelease) btnRelease.disabled = false;
        startBuzzer();
    }

    function unlockReading() {
        stopBuzzer();
        locked = false;
        if (qrInput) {
            qrInput.disabled = false;
            qrInput.value = "";
            qrInput.focus();
        }
        if (input) input.disabled = false;
        if (btnRelease) btnRelease.disabled = true;
    }

    // リリースボタン
    if (btnRelease) btnRelease.addEventListener("click", unlockReading);

    // 初期フォーカスは QR 入力欄
    window.addEventListener("load", () => {
        if (qrInput) qrInput.focus();
    });

    // QR入力: Enterで Lookup を呼び、成功したらフォームに反映（その後は手動で登録）
    if (qrInput) {
        qrInput.addEventListener("keydown", async (e) => {
            if (e.key !== "Enter") return;

            const code = (qrInput.value || "").trim();

            if (!code) return;
            if (locked) return;

            // まず Lookup API を呼ぶ
            try {
                const res = await fetch('@Url.Action("Lookup", "Scan")', {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ code: code })
                });

                const data = await res.json();

                if (!data || data.ok !== true) {
                    // Lookup失敗
                    setIcon("NG");
                    playBeep("NG");
                    appendLog(`${code} ${data?.message ?? "Lookup failed"}`);
                    showReadResult(code, data?.message ?? "取得失敗", "");
                    lockReading();
                    return;
                }

                // 成功：フォームへ反映
                if (input) input.value = data.code ?? code;
                if (companyCdEl) companyCdEl.value = data.cooperateCd ?? "";
                if (companyKanaEl) companyKanaEl.value = data.companyKana ?? "";
                if (companyNameEl) companyNameEl.value = data.companyName ?? "";
                if (workerKanaEl) workerKanaEl.value = data.workerKana ?? "";
                if (workerNameEl) workerNameEl.value = data.workerName ?? "";
                if (birthDateEl && data.birthYmd) {
                    // birthYmd expected "YYYYMMDD"
                    const by = String(data.birthYmd || "");
                    if (by.length === 8) {
                        birthDateEl.value = `${by.substring(0,4)}-${by.substring(4,6)}-${by.substring(6,8)}`;
                    } else {
                        birthDateEl.value = "";
                    }
                }

                const displayName = data.workerName ?? (data.workerKana ?? "");
                showReadResult(data.code ?? code, displayName, "");
                setIcon("OK");
                playBeep("OK");
                appendLog(`${data.code ?? code} ${displayName} 取得OK`);

                // フォーカスは QR欄に戻して連続読取に備える
                if (qrInput) { qrInput.value = ""; qrInput.focus(); }
            } catch (ex) {
                setIcon("NG");
                playBeep("NG");
                appendLog(`ERR ${ex}`);
                showReadResult(code, "エラー", "");
                lockReading();
            }
        });
    }

    // Temp 登録ボタンの既存処理は維持
    const registerButton = document.getElementById("btnTempRegister");
    if (registerButton) {
        registerButton.addEventListener("click", async () => {
            const companyCd = (document.getElementById("companyCd")?.value || "").trim();
            const workerName = (document.getElementById("workerName")?.value || "").trim();

            if (!companyCd || !workerName) {
                alert("協力会社コード・作業員名は必須です");
                return;
            }

            const res = await fetch('@Url.Action("TempRecord", "Scan")', {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    companyCd: companyCd,
                    workerName: workerName,
                    kind: "@kind"
                })
            });

            const data = await res.json();
            const time = data.time ? `${data.time.slice(0, 2)}:${data.time.slice(2, 4)}` : "";

            showReadResult(data.code || "TEMP", workerName, time);
            setIcon(data.ok ? "OK" : "WARN");
            appendLog(`${data.time ?? ""} ${data.message ?? ""}`);
        });
    }
</script>
</body>
</html>
