@using QRAttendMvc.Models
@{
    Layout = null;

    string kind = ViewBag.Kind as string ?? "IN";
    string modeLabel = kind == "IN" ? "入場" : "退場";
    string title = "入退場登録（臨時対応）";
    string kaisaiCd = ViewBag.CurrentKaisaiCd as string ?? "";
    string login = ViewBag.LoginDisplay as string ?? "XXXXXX";
    var ev = ViewBag.Event as Gt01KaisaiEvent ?? new Gt01KaisaiEvent();

    var serverNow = DateTime.Now;
    var w = new[] { "日", "月", "火", "水", "木", "金", "土" };
    var youbi = w[(int)serverNow.DayOfWeek];

    // テスト用  start 2026.02.20 Takada
    var selected = Context.Request.Query["COOPERATE_CD"].ToString();
    var selectedEmployeeCd = Context.Request.Query["EMPLOYEE_CD"].ToString();
    // テスト用  end   2026.02.20 Takada

    ViewData["Title"] = title;

    string FmtYmd(string? ymd)
    {
        if (string.IsNullOrWhiteSpace(ymd)) return "";
        return ymd.Replace("-", "/");
    }

    string FmtHm(string? hhmm)
    {
        if (string.IsNullOrWhiteSpace(hhmm)) return "";
        var s = hhmm.Trim().PadLeft(4, '0');
        return s.Substring(0, 2) + ":" + s.Substring(2, 2);
    }
}

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 協力会社入退場記録システム</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/scan-result.css" />
    <link rel="stylesheet" href="~/css/entryexit-batch.css" />

    <style>
        /* 下線のみ表示する readonly 用スタイル（枠を取り除き下線のみ） */
        .ev-selectlike.ev-readonly.ev-underline {
            border: none;
            border-bottom: 2px solid #1d1d1d;
            background: transparent;
            box-shadow: none;
            padding: 2px 0px;
            padding-left: .25rem;
            padding-right: .25rem;
            line-height: 1.5;
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            width: 208px !important;
            border-radius: inherit;
        }

        .ev-selectlike.ev-readonly.ev-underline:focus {
            outline: none;
            box-shadow: none;
        }

        /* readonly なのでカーソルはデフォルトにする */
        .ev-selectlike.ev-readonly.ev-underline[readonly] {
            cursor: default;
        }

        .ev-underline-only {
            border: none;
            border-bottom: 2px solid #1d1d1d;
            background: transparent;
            box-shadow: none;
        }

        .ev-underline-only:focus {
            outline: none;
            box-shadow: none;
        }

        .ev-underline-only[readonly] {
            cursor: default;
        }

        /* 小さめの検索ボタン（色は既存の btn-primary を継承） */
        .ee-btn-small,
        .btn-search {
            padding: .25rem .5rem;
            font-size: 10px;
            line-height: 1;
            width: 120px;
            min-width: 120px;
            height: 18px;
            min-height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
        }

        /* 親の .ev-field 内で余白を調整（レイアウト崩れを抑える） */
        .ev-row .ev-field {
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        /* ボタンがテキスト入力と揃うように高さ微調整 */
        .ev-row .ev-field .form-control + .btn,
        .ev-row .ev-field input + .btn {
            margin-left: 0;
        }

        /* 姓・名を横並びにするスタイル */
        .name-split {
            display: flex;
            gap: .5rem;
        }

        .name-split .name-split-input {
            width: 30%;
            min-width: 6rem;
        }

        /* モバイルで狭い場合は縦並びに落とす */
        @@media (max-width: 520px) {
            .name-split {
                flex-direction: column;
            }

            .name-split .name-split-input {
                width: 100%;
            }
        }

        .btn-disabled {
            opacity: .55;
            pointer-events: none;
        }
    </style>
</head>

<body class="event-page">
    <div class="ee-header">
        <div class="ev-tab @(kind == "IN" ? "ev-mode-in" : "ev-mode-out")">@modeLabel</div>
        <div class="ev-title">@title</div>
    </div>

    <div class="card ee-card">
        @if (string.IsNullOrEmpty(kaisaiCd) || ev == null)
        {
            <div class="alert alert-warning">
                イベントが確定していません。先に「イベント選択」で確定してください。
            </div>
        }
        else
        {
            <div class="ee-top">
                <div class="ee-event">
                    <div class="ee-row"><div class="ee-k">イベント開催日</div><div class="ee-v">@FmtYmd(ev.KaisaiYmd)</div></div>
                    <div class="ee-row"><div class="ee-k">区分</div><div class="ee-v">@($"{ev.EventCd} {ev.EventName}")</div></div>
                    <div class="ee-row"><div class="ee-k">開催拠点</div><div class="ee-v">@($"{ev.BranchCd} {ev.BranchName}")</div></div>
                    <div class="ee-row"><div class="ee-k">受講場所</div><div class="ee-v">@ev.Location</div></div>
                    <div class="ee-row ee-row-inline">
                        <div class="ee-k">開催時刻</div>
                        <div class="ee-v">@($"{FmtHm(ev.StartTime)} ～ {FmtHm(ev.EndTime)}")</div>
                        <div class="ee-k ee-k-small">受付開始時刻</div>
                        <div class="ee-v ee-v-small">@FmtHm(ev.ReceptTime)</div>
                        <div class="ee-now-label">現在時刻</div>
                        <div id="layoutTime" class="ee-now-time"></div>
                    </div>
                </div>

                <div class="ee-side">
                    <div class="ee-login" aria-label="ログイン情報">
                        <div class="ev-login-row">
                            <span class="ev-login-label">ログイン</span>
                            <span class="ev-login-value">@login</span>
                        </div>
                        <div class="ev-login-row">
                            <span class="ev-login-label">日付</span>
                            <span class="ev-login-value">@serverNow.ToString("yyyy/MM/dd") (@youbi)</span>
                        </div>
                        <div class="ev-login-row">
                            <span class="ev-login-label">時刻</span>
                            <span class="ev-login-value">@serverNow.ToString("HH:mm:ss")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 臨時入力を EventSelection と同様に縦並びに変更 -->
            <div class="ee-temp-form">
                <div class="ev-form">
                    <div class="ev-row">
                        <div class="ev-label">作業員ID</div>
                        <div class="ev-field">
                            <!-- 非入力（下線表示）、フォーカス不可 -->
                            <input id="scanInput" class="ev-selectlike ev-readonly ev-underline" readonly tabindex="-1" aria-hidden="true" />
                            <button id="btnWorkerSearch" class="btn btn-primary ee-btn ee-btn-back ee-btn-small btn-search" type="button" aria-label="作業員検索">作業員検索</button>
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">協力会社コード</div>
                        <div class="ev-field">
                            <input id="companyCd" class="ev-selectlike ev-readonly ev-underline" readonly tabindex="-1" aria-hidden="true" />
                            <button id="btnCompanySearch" class="btn btn-primary ee-btn ee-btn-back ee-btn-small btn-search" type="button" aria-label="会社検索">会社検索</button>
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">会社名カナ</div>
                        <div class="ev-field">
                            <input id="companyKana" class="ev-selectlike ev-readonly ev-underline" readonly tabindex="-1" aria-hidden="true" style="width: 100% !important;" />
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">会社名</div>
                        <div class="ev-field">
                            <input id="companyName" class="ev-selectlike ev-readonly ev-underline" readonly tabindex="-1" aria-hidden="true" style="width: 100% !important;" />
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">作業員名カナ</div>
                        <div class="ev-field name-split">
                            <input id="workerFamilyKana" class="form-control name-split-input" placeholder="姓（カナ）" inputmode="kana" lang="ja" autocomplete="off" />
                            <input id="workerFirstKana" class="form-control name-split-input" placeholder="名（カナ）" inputmode="kana" lang="ja" autocomplete="off" />
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">作業員名</div>
                        <div class="ev-field name-split">
                            <input id="workerFamilyName" class="form-control name-split-input" placeholder="姓" lang="ja" autocomplete="off" />
                            <input id="workerFirstName" class="form-control name-split-input" placeholder="名" lang="ja" autocomplete="off" />
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">生年月日</div>
                        <div class="ev-field">
                            <!-- 手入力で 8桁許容。画面表示は YYYY/MM/DD -->
                            <input id="birthDate" type="text" class="form-control" style="width: 94px" placeholder="YYYY/MM/DD" autocomplete="bday" inputmode="numeric" pattern="[0-9/]*" />
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">名簿対象除外日</div>
                        <div class="ev-field">
                            <input id="excludeDate" type="text" class="ev-selectlike ev-readonly ev-underline" readonly tabindex="-1" aria-hidden="true" style="width: 94px !important" />
                        </div>
                    </div>

                    <div class="ev-row">
                        <div class="ev-label">入場記録</div>
                        <div class="ev-field">
                            <!-- 時刻（時:分）入力。step=60で分単位 -->
                            <input id="entryRecord" type="time" step="60" class="form-control form-control-sm" style="width: 80px !important" />
                        </div>
                    </div>

                    @* 入場時は退場欄を非表示にする *@
                    @if (kind != "IN")
                    {
                        <div class="ev-row">
                            <div class="ev-label">退場記録</div>
                            <div class="ev-field">
                                <input id="exitRecord" type="time" step="60" class="form-control form-control-sm" style="width: 80px !important" />
                            </div>
                        </div>
                    }

                    <div class="ev-row">
                        <div class="ev-label">事由</div>
                        <div class="ev-field">
                            <select id="reason" class="form-control" style="height: 18px;">
                                <option value="">(選択必須)</option>
                                <option value="E1">E1：従事者証忘れ</option>
                                <option value="E2">E2：従事者証未発行</option>
                                <option value="E3">E3：会社代表または、営業担当者</option>
                                <option value="E4">E4：QRコード読み取り不可</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- 結果エリア：左に緑のアイコン、右に結果コメント（大きめのテキストエリア） -->
                <div class="ev-row" style="grid-template-columns: 140px 1fr !important;align-items: self-start;">
                    <div class="ee-result-wrap">
                        <div class="ee-result-left">
                            <div class="ev-label ee-result-label">結果</div>
                            <div class="ee-result-box">
                                 <img id="resultIcon" class="result-icon" src="/images/Circle.png" alt="結果" style="visibility:hidden" />
                             </div>
                        </div>
                    </div>
                    <div>
                        <div class="ee-result-comment">
                            <div class="ee-section-title">結果コメント</div>
                            <div class="ee-log-box">
                                <textarea id="logArea" class="ee-log" rows="6" readonly></textarea>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        }
        <div class="ee-footer">
            <button id="btnTempRegister" class="btn btn-primary ee-btn ee-btn-back" type="button">登録</button>
            <form asp-action="BackToEventSelectionTemp" method="post" style="display:inline;">
                <input type="hidden" name="kind" value="@kind" />
                <button id="btnBackToEventSelection" type="submit" class="btn ee-btn btn-primary ee-btn-back">
                    イベント選択画面に戻る
                </button>
            </form>
        </div>

        <!-- QRスキャナ入力 -->
        <div class="ee-input">
            <input id="qrScanInput" class="form-control form-control visually-hidden-input"
                    placeholder="ここにカーソルを置いたままQRを読み取ります" autocomplete="off" autocorrect="off" spellcheck="false" />
        </div>



    </div>

<script>
    const qrInput = document.getElementById("qrScanInput");
    const input = document.getElementById("scanInput"); // 作業員ID表示欄 (readonly)
    const companyCdEl = document.getElementById("companyCd");
    const companyKanaEl = document.getElementById("companyKana");
    const companyNameEl = document.getElementById("companyName");
    const workerFamilyKanaEl = document.getElementById("workerFamilyKana");
    const workerFirstKanaEl = document.getElementById("workerFirstKana");
    const workerFamilyNameEl = document.getElementById("workerFamilyName");
    const workerFirstNameEl = document.getElementById("workerFirstName");
    const birthDateEl = document.getElementById("birthDate");
    const excludeDateEl = document.getElementById("excludeDate");
    const entryRecordEl = document.getElementById("entryRecord");
    const exitRecordEl = document.getElementById("exitRecord");
    const reasonEl = document.getElementById("reason");
    const btnCompanySearch = document.getElementById("btnCompanySearch");
    const btnBackToEventSelection = document.getElementById("btnBackToEventSelection");

    const logArea = document.getElementById("logArea");
    const lastCode = document.getElementById("lastCode");
    const lastName = document.getElementById("lastName");
    const lastTime = document.getElementById("lastTime");
    const resultIcon = document.getElementById("resultIcon");

    const kind = "@kind";
    const kaisaiCd = "@kaisaiCd";
    const evKaisaiCd = "@kaisaiCd";
    const serverStart = new Date("@serverNow.ToString("yyyy-MM-ddTHH:mm:ss")");
    const clientStart = Date.now();

    //追加 2026.02.20 Takada start:作業員検索からのデータ保持
    const selectedEmployeeCd = "@selectedEmployeeCd";
    const selectedCooperateCd = "@selected";
    //追加 2026.02.20 Takada end  ;作業員検索からのデータ保持

    let editingTemp = false;
    let currentQrPrefix = null; // '1' or '2' when set by QR scan

    const formStateKey = "TempInputFormState";

    function saveFormState() {
        const state = {
            companyCd: companyCdEl?.value || "",
            companyKana: companyKanaEl?.value || "",
            companyName: companyNameEl?.value || "",
            workerFamilyKana: workerFamilyKanaEl?.value || "",
            workerFirstKana: workerFirstKanaEl?.value || "",
            workerFamilyName: workerFamilyNameEl?.value || "",
            workerFirstName: workerFirstNameEl?.value || "",
            birthDate: birthDateEl?.value || "",
            entryRecord: entryRecordEl?.value || "",
            exitRecord: exitRecordEl?.value || "",
            reason: reasonEl?.value || "",
            workerId: input?.value || "",
            excludeDate: excludeDateEl?.value || "",
            logArea: logArea?.value || "",
            resultIconSrc: resultIcon?.getAttribute("src") || "",
            resultIconAlt: resultIcon?.getAttribute("alt") || "",
            resultIconVisible: !!(resultIcon && resultIcon.style.visibility !== "hidden" && resultIcon.style.visibility !== ""),
            isLocked: !!(workerFamilyKanaEl && workerFamilyKanaEl.readOnly),
            currentQrPrefix
        };
        sessionStorage.setItem(formStateKey, JSON.stringify(state));
    }

    function restoreFormState() {
        const payload = sessionStorage.getItem(formStateKey);
        if (!payload) {
            setInputLock(false);
            return;
        }
        try {
            const state = JSON.parse(payload);
            if (companyCdEl) companyCdEl.value = state.companyCd || "";
            if (companyKanaEl) companyKanaEl.value = state.companyKana || "";
            if (companyNameEl) companyNameEl.value = state.companyName || "";
            if (workerFamilyKanaEl) workerFamilyKanaEl.value = state.workerFamilyKana || "";
            if (workerFirstKanaEl) workerFirstKanaEl.value = state.workerFirstKana || "";
            if (workerFamilyNameEl) workerFamilyNameEl.value = state.workerFamilyName || "";
            if (workerFirstNameEl) workerFirstNameEl.value = state.workerFirstName || "";
            if (birthDateEl) birthDateEl.value = state.birthDate || "";
            if (entryRecordEl) entryRecordEl.value = state.entryRecord || "";
            if (exitRecordEl) exitRecordEl.value = state.exitRecord || "";
            if (reasonEl) reasonEl.value = state.reason || "";
            if (input) input.value = state.workerId || "";
            if (excludeDateEl) excludeDateEl.value = state.excludeDate || "";
            if (logArea) logArea.value = state.logArea || "";
            if (resultIcon) {
                if (state.resultIconVisible && state.resultIconSrc) {
                    resultIcon.src = state.resultIconSrc;
                    resultIcon.alt = state.resultIconAlt || "";
                    resultIcon.style.visibility = "visible";
                } else {
                    resultIcon.style.visibility = "hidden";
                }
            }
            if (typeof state.isLocked === "boolean") {
                setInputLock(state.isLocked);
            } else {
                setInputLock(false);
            }
            currentQrPrefix = state.currentQrPrefix || currentQrPrefix;
        }
        catch {
            sessionStorage.removeItem(formStateKey);
            setInputLock(false);
        }
    }

    function setInputLock(isLocked) {
        const fields = [workerFamilyKanaEl, workerFirstKanaEl, workerFamilyNameEl, workerFirstNameEl, birthDateEl];
        fields.forEach(f => {
            if (!f) return;
            if (isLocked) {
                f.readOnly = true;
                f.classList.add("ev-underline-only");
            } else {
                f.readOnly = false;
                f.classList.remove("ev-underline-only");
            }
        });

        if (btnCompanySearch) {
            btnCompanySearch.disabled = isLocked;
            btnCompanySearch.classList.toggle("btn-disabled", isLocked);
        }
    }

    function clearLookupFields() {
        if (companyCdEl) companyCdEl.value = "";
        if (companyKanaEl) companyKanaEl.value = "";
        if (companyNameEl) companyNameEl.value = "";
        if (workerFamilyKanaEl) workerFamilyKanaEl.value = "";
        if (workerFirstKanaEl) workerFirstKanaEl.value = "";
        if (workerFamilyNameEl) workerFamilyNameEl.value = "";
        if (workerFirstNameEl) workerFirstNameEl.value = "";
        if (birthDateEl) birthDateEl.value = "";
        if (excludeDateEl) excludeDateEl.value = "";
        if (entryRecordEl) entryRecordEl.value = "";
        if (exitRecordEl) exitRecordEl.value = "";
    }

    function appendLog(line) {
        if (!logArea) return;
        const prev = logArea.value || "";
        logArea.value = (line + "\n" + prev).trimEnd();
    }

    function setIcon(result) {
        if (!resultIcon) return;
        let src = "";
        let alt = "";
        if (result === "OK") { src = "@Url.Content("~/images/Circle.png")"; alt = "正常"; }
        else if (result === "WARN") { src = "@Url.Content("~/images/Triangle.png")"; alt = "警告"; }
        else if (result === "NG") { src = "@Url.Content("~/images/Cross.png")"; alt = "エラー"; }

        resultIcon.src = src;
        resultIcon.alt = alt;
        resultIcon.style.visibility = "visible";
        resultIcon.classList.remove("pop-animate");
        void resultIcon.offsetWidth;
        resultIcon.classList.add("pop-animate");
    }

    function showReadResult(code, name, timeText) {
        if (lastCode) lastCode.textContent = code || "－";
        if (lastName) lastName.textContent = name || "－";
        if (lastTime) lastTime.textContent = timeText || "";
    }

    function playBeep(result) {
        try {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;
            const ctx = new AudioCtx();
            if (ctx.state === "suspended") ctx.resume();

            const osc = ctx.createOscillator();
            const gain = ctx.createGain();

            const freq = result === "OK" ? 880 : result === "WARN" ? 660 : 220;
            osc.type = "sine";
            osc.frequency.value = freq;

            const t0 = ctx.currentTime;
            gain.gain.setValueAtTime(0.0001, t0);
            gain.gain.exponentialRampToValueAtTime(0.18, t0 + 0.01);
            gain.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.12);

            osc.connect(gain);
            gain.connect(ctx.destination);

            osc.start(t0);
            osc.stop(t0 + 0.13);
            osc.onended = () => { try { ctx.close(); } catch (e) {} };
        } catch (e) {}
    }

    (function initFocusBehavior() {
        const tempForm = document.querySelector('.ee-temp-form');
        if (tempForm) {
            tempForm.addEventListener('focusin', () => { editingTemp = true; });
            tempForm.addEventListener('focusout', () => {
                setTimeout(() => {
                    const active = document.activeElement;
                    editingTemp = tempForm.contains(active);
                }, 0);
            });
        }

        function onPointerForFocus(e) {
            try {
                if (editingTemp) return;

                const target = e.target;
                if (!target) return;

                const tag = (target.tagName || '').toLowerCase();
                const isInteractive = (
                    tag === 'input' ||
                    tag === 'select' ||
                    tag === 'textarea' ||
                    tag === 'button' ||
                    tag === 'a' ||
                    (target.isContentEditable === true)
                );
                if (isInteractive || (target.closest && target.closest('input,select,textarea,button,a,[contenteditable="true"]'))) {
                    return;
                }

                if (qrInput && typeof qrInput.focus === 'function') {
                    try { qrInput.focus(); } catch (e) {}
                }
            } catch (ex) {}
        }

        document.addEventListener('click', onPointerForFocus, true);
        document.addEventListener('touchstart', onPointerForFocus, { passive: true, capture: true });
    })();

    // --- 生年月日：手入力 8桁許容、画面表示は YYYY/MM/DD ---
    function formatToDisplayYmd(raw) {
        if (!raw) return "";
        const digits = String(raw).replace(/[^\d]/g, "");
        if (digits.length === 8) {
            return digits.substring(0,4) + "/" + digits.substring(4,6) + "/" + digits.substring(6,8);
        }
        // 既に yyyy-mm-dd や yyyy/mm/dd の場合はスラッシュで整形
        const m = String(raw).match(/^(\d{4})[-\/](\d{2})[-\/](\d{2})$/);
        if (m) return `${m[1]}/${m[2]}/${m[3]}`;
        return String(raw);
    }

    function toIsoDate(raw) {
        if (!raw) return "";
        const digits = String(raw).replace(/[^\d]/g, "");
        if (digits.length === 8) {
            return `${digits.substring(0,4)}-${digits.substring(4,6)}-${digits.substring(6,8)}`;
        }
        // try parseable value (leave as-is)
        return String(raw);
    }

    function isValidBirthDate(raw) {
        const iso = toIsoDate(raw);
        if (!iso) return false;
        const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!m) return false;
        const y = Number(m[1]);
        const mo = Number(m[2]);
        const d = Number(m[3]);
        const dt = new Date(y, mo - 1, d);
        return dt.getFullYear() === y && dt.getMonth() === (mo - 1) && dt.getDate() === d;
    }

    if (birthDateEl) {
        // 入力中に 8桁そろったら自動整形
        birthDateEl.addEventListener('input', (e) => {
            try {
                const v = birthDateEl.value || "";
                if (hasNonNumeric(v)) {
                    showNumericBalloon(birthDateEl);
                }

                const sanitized = v.replace(/[^\d/]/g, "");
                const onlyDigits = sanitized.replace(/\//g, "");

                if (onlyDigits.length === 8) {
                    const disp = formatToDisplayYmd(onlyDigits);
                    birthDateEl.value = disp;
                } else if (v !== sanitized) {
                    birthDateEl.value = sanitized;
                }
            } catch (ex) {}
        });

        // 失念防止: blur 時にも可能な限り整形
        birthDateEl.addEventListener('blur', (e) => {
            try {
                const v = (birthDateEl.value || "").trim();
                birthDateEl.value = formatToDisplayYmd(v);
            } catch (ex) {}
        });
    }

    function normalizeToKatakana(value) {
        if (!value) return "";

        const nk = String(value).normalize("NFKC");

        const kata = nk.replace(/[ぁ-ん]/g, ch =>
            String.fromCharCode(ch.charCodeAt(0) + 0x60)
        );

        return kata.replace(/[^\u30A0-\u30FF\s　ー]/g, "");
    }

    function hasNonKana(value) {
        if (!value) return false;
        return /[^\u3040-\u309F\u30A0-\u30FF\s　ー]/.test(String(value));
    }

    function showKanaBalloon(el) {
        if (!el || typeof el.setCustomValidity !== "function") return;
        const message = "カタカナのみ入力できます。";
        el.setCustomValidity(message);
        try {
            if (typeof el.reportValidity === "function") {
                el.reportValidity();
            }
        } catch (e) {}
        setTimeout(() => {
            try { el.setCustomValidity(""); } catch (e) {}
        }, 5000);
    }

    function hasNonNumeric(value) {
        if (!value) return false;
        return /[^\d/]/.test(String(value));
    }

    function showNumericBalloon(el) {
        if (!el || typeof el.setCustomValidity !== "function") return;
        const message = "数字と / のみ入力できます。";
        el.setCustomValidity(message);
        try {
            if (typeof el.reportValidity === "function") {
                el.reportValidity();
            }
        } catch (e) {}
        setTimeout(() => {
            try { el.setCustomValidity(""); } catch (e) {}
        }, 5000);
    }

    function attachKanaOnlyHandler(el) {
        if (!el) return;

        let composing = false;

        el.addEventListener("compositionstart", () => {
            composing = true;
        });

        el.addEventListener("compositionend", () => {
            composing = false;
            if (!el.readOnly && hasNonKana(el.value)) {
                showKanaBalloon(el);
            }
            el.value = normalizeToKatakana(el.value);
        });

        el.addEventListener("input", () => {
            if (el.readOnly || composing) return;

            if (hasNonKana(el.value)) {
                showKanaBalloon(el);
            }

            const next = normalizeToKatakana(el.value);
            if (el.value !== next) {
                el.value = next;
            }
        });

        el.addEventListener("blur", () => {
            if (el.readOnly) return;
            el.value = normalizeToKatakana(el.value);
        });
    }

    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".js-kana-only").forEach(attachKanaOnlyHandler);
    });

    attachKanaOnlyHandler(workerFamilyKanaEl);
    attachKanaOnlyHandler(workerFirstKanaEl);

    function parseQrString(raw) {
        if (!raw) return { ok: false, reason: "empty" };
        if (!raw.includes(",")) return { ok: false, reason: "no-comma", original: raw };

        const s = raw.trim();
        const parts = s.split(",").map(p => p.trim());
        if (parts.length < 2) return { ok: false, reason: "invalid-parts", original: s };

        const prefix = parts[0];
        if (prefix !== "1" && prefix !== "2") return { ok: false, reason: "invalid-prefix", original: s };

        if (prefix === "1") {
            if (parts.length !== 2) return { ok: false, reason: "invalid-parts-1", original: s };
            return { ok: true, type: "1", worker: parts[1], overrideKaisai: null, original: s };
        }

        if (parts.length < 3) return { ok: false, reason: "invalid-parts-2", original: s };
        return { ok: true, type: "2", worker: parts[1], overrideKaisai: parts[2], original: s };
    }

    if (qrInput) {
        qrInput.addEventListener("keydown", async (e) => {
            if (e.key !== "Enter") return;

            const raw = (qrInput.value || "").trim();
            if (!raw) return;

            const parsed = parseQrString(raw);

            try {
                await fetch('@Url.Action("TempQrReadLog", "Scan")', {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ kind: kind, workerCd: parsed.worker || "" })
                });
            } catch (ex) { }

            if (!parsed.ok) {
                setIcon("NG");
                playBeep("NG");
                const msg = parsed.reason === "no-comma" ? "QR形式不正（, が必要です）" :
                            parsed.reason === "invalid-prefix" ? "QR区分不正" :
                            parsed.reason === "invalid-parts-2" ? "仮QRは '2,作業員ID,イベントCD' の形式が必要です" :
                            "QR形式不正";
                appendLog(`${raw} ${msg}`);
                showReadResult(raw, msg, "");
                if (qrInput) { qrInput.value = ""; }
                return;
            }

            if (parsed.type === "2") {
                const qrKaisai = parsed.overrideKaisai || "";
                if (qrKaisai !== evKaisaiCd) {
                    setIcon("NG");
                    playBeep("NG");
                    appendLog(`${parsed.original} 仮QRの開催コードが表示中の開催コードと一致しません （QR:${qrKaisai} != ${evKaisaiCd}）`);
                    showReadResult(parsed.worker || parsed.original, "開催コード不一致", "");
                    if (qrInput) { qrInput.value = ""; }
                    return;
                }
            }

            const workerForLookup = parsed.worker || parsed.original;
            // remember prefix for later (TempRecord)
            currentQrPrefix = parsed.type;

            try {
                const res = await fetch('@Url.Action("Lookup", "Scan")', {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ code: workerForLookup, prefix: parsed.type })
                });

                const data = await res.json();

                if (!data || data.ok !== true) {
                    const isNoMaster = (data?.message ?? "") === "作業員マスタに登録がありません";
                    setIcon(isNoMaster ? "WARN" : "NG");
                    playBeep(isNoMaster ? "WARN" : "NG");
                    appendLog(`${workerForLookup} ${data?.message ?? "Lookup failed"}`);
                    showReadResult(workerForLookup, data?.message ?? "取得失敗", "");
                    if (qrInput) { qrInput.value = ""; }
                    return;
                }

                sessionStorage.removeItem(formStateKey);
                clearLookupFields();

                 if (input) input.value = data.code ?? workerForLookup;
                 if (companyCdEl) companyCdEl.value = data.cooperateCd ?? "";
                 if (companyKanaEl) companyKanaEl.value = data.companyKana ?? "";
                 if (companyNameEl) companyNameEl.value = data.companyName ?? "";

                setInputLock(parsed.type === "1");

                // 新しい分割フィールドにセット（存在しない場合は従来フィールド workerKana/workerName を分割） 
                if (workerFamilyKanaEl) workerFamilyKanaEl.value = data.workerFamilyKana ?? (data.workerKana ? (data.workerKana.split(" ")[0] || "") : "");
                if (workerFirstKanaEl) workerFirstKanaEl.value = data.workerFirstKana ?? (data.workerKana ? (data.workerKana.split(" ")[1] || "") : "");
                if (workerFamilyNameEl) workerFamilyNameEl.value = data.workerFamilyName ?? "";
                if (workerFirstNameEl) workerFirstNameEl.value = data.workerFirstName ?? "";

                if (birthDateEl && data.birthYmd) {
                    const by = String(data.birthYmd || "");
                    if (by.length === 8) {
                        // 画面表示は YYYY/MM/DD にする
                        birthDateEl.value = `${by.substring(0,4)}/${by.substring(4,6)}/${by.substring(6,8)}`;
                    } else {
                        birthDateEl.value = "";
                    }
                }

                // 除外日を表示（サーバ側で既にフォーマット済み）
                if (excludeDateEl) {
                    excludeDateEl.value = data.excludeDate ?? "";
                }

                // 既存の入退場時刻が返されていれば画面に反映する
                try {
                    const et = data.entryTime || "";
                    const xt = data.exitTime || "";
                    if (et && entryRecordEl) {
                        entryRecordEl.value = (et.length >= 4) ? (et.slice(0,2) + ":" + et.slice(2,4)) : et;
                    }
                    if (xt && exitRecordEl) {
                        exitRecordEl.value = (xt.length >= 4) ? (xt.slice(0,2) + ":" + xt.slice(2,4)) : xt;
                    }
                } catch (ex) {}

                const displayName = (data.workerFamilyName || "") + (data.workerFirstName ? (" " + data.workerFirstName) : "") || (data.workerName ?? (data.workerKana ?? ""));
                // 表示する時刻は入場があれば入場、なければ退場を優先して表示
                let timeToShow = "";
                try {
                    if (data.entryTime) timeToShow = (data.entryTime.length >= 4) ? (data.entryTime.slice(0,2) + ":" + data.entryTime.slice(2,4)) : data.entryTime;
                    else if (data.exitTime) timeToShow = (data.exitTime.length >= 4) ? (data.exitTime.slice(0,2) + ":" + data.exitTime.slice(2,4)) : data.exitTime;
                } catch (ex) { timeToShow = ""; }

                showReadResult(data.code ?? workerForLookup, displayName, timeToShow);
                setIcon("OK");
                playBeep("OK");
                appendLog(`${data.code ?? workerForLookup} ${displayName} 取得OK`);

                if (qrInput) { qrInput.value = ""; }
            } catch (ex) {
                setIcon("NG");
                playBeep("NG");
                appendLog(`ERR ${ex}`);
                showReadResult(raw, "エラー", "");
                if (qrInput) { qrInput.value = ""; }
            }
        });
    }

    const registerButton = document.getElementById("btnTempRegister");
    if (registerButton) {
        registerButton.addEventListener("click", async () => {
            const companyCd = (companyCdEl?.value || "").trim();
            const companyKana = (companyKanaEl?.value || "").trim();
            const companyName = (companyNameEl?.value || "").trim();
            const familyName = (workerFamilyNameEl?.value || "").trim();
            const firstName = (workerFirstNameEl?.value || "").trim();
            const familyKana = (workerFamilyKanaEl?.value || "").trim();
            const firstKana = (workerFirstKanaEl?.value || "").trim();
            const workerName = [familyName, firstName].filter(Boolean).join(" ").trim();
            const workerKana = [familyKana, firstKana].filter(Boolean).join(" ").trim();
            const birthDateRaw = (birthDateEl?.value || "").trim();
            // サーバに送る生年月日は ISO 形式 (yyyy-MM-dd) に正規化
            const birthDate = toIsoDate(birthDateRaw);
            const excludeDate = (excludeDateEl?.value || "").trim();
            const entryRecordRaw = (entryRecordEl?.value || "").trim();
            const entryRecord = entryRecordRaw.includes(":") ? entryRecordRaw.replace(":", "") : entryRecordRaw;
            const exitRecordRaw = (exitRecordEl?.value || "").trim();
            const exitRecord = exitRecordRaw.includes(":") ? exitRecordRaw.replace(":", "") : exitRecordRaw;
            const reason = (reasonEl?.value || "").trim();
            const workerCd = (input?.value || "").trim();

            const reasonRequired = !(workerFamilyKanaEl && workerFamilyKanaEl.readOnly);

            if (!workerCd || !workerKana || !companyCd || !birthDateRaw || (reasonRequired && !reason)) {
                alert(reasonRequired
                    ? "作業員ID・協力会社コード・作業員名カナ・生年月日・事由は必須です。"
                    : "作業員ID・協力会社コード・作業員名カナ・生年月日は必須です。");
                return;
            }

            if (!isValidBirthDate(birthDateRaw)) {
                alert("生年月日が不正です。");
                return;
            }

            registerButton.disabled = true;

            try {
                const payload = {
                    companyCd: companyCd,
                    companyKana: companyKana,
                    companyName: companyName,
                    workerName: workerName,
                    workerKana: workerKana,
                    workerCd: workerCd,
                    qrPrefix: currentQrPrefix,
                    birthDate: birthDate,
                    excludeDate: excludeDate,
                    entryRecord: entryRecord,
                    exitRecord: exitRecord,
                    kind: "@kind",
                    reason: reason,
                    kaisaiCd: "@kaisaiCd"
                };

                const res = await fetch('@Url.Action("TempRecord", "Scan")', {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();
                const time = data.time ? `${data.time.slice(0, 2)}:${data.time.slice(2, 4)}` : "";

                showReadResult(data.code || "TEMP", workerName, time);
                setIcon(data.ok ? "OK" : "WARN");
                playBeep(data.ok ? "OK" : "WARN");
                const logLine = [data.time ?? "", data.message ?? ""].filter(v => v && v.trim()).join(" ");
                appendLog(logLine);

                if (data.ok) {
                    try {
                        companyCdEl.value = "";
                        companyKanaEl.value = "";
                        companyNameEl.value = "";
                        workerFamilyKanaEl.value = "";
                        workerFirstKanaEl.value = "";
                        workerFamilyNameEl.value = "";
                        workerFirstNameEl.value = "";
                        birthDateEl.value = "";
                        excludeDateEl.value = "";
                        entryRecordEl.value = "";
                        if (exitRecordEl) exitRecordEl.value = "";
                        reasonEl.value = "";
                        if (input) input.value = "";
                        currentQrPrefix = null;
                        setInputLock(false);
                        sessionStorage.removeItem(formStateKey);
                    } catch (e) {}
                } else {
                    // WARN/NGでも画面ロックしない
                }
            } catch (ex) {
                setIcon("NG");
                playBeep("NG");
                appendLog(`ERR ${ex}`);
            } finally {
                registerButton.disabled = false;
            }
        });
    }

    // 受付開始時間の右に現在時刻を表示（Batch と同等の更新）
    function updateLayoutClock() {
        const d = new Date(serverStart.getTime() + (Date.now() - clientStart));
        const pad = n => String(n).padStart(2, '0');
        const time = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;

        const el = document.getElementById("layoutTime");
        if (el) el.textContent = time;
    }
    updateLayoutClock();
    setInterval(updateLayoutClock, 1000);

    // 追加 2023.02.20 Takada ; 検索画面から戻ってEMPLOYEE_CD
    // 検索画面から戻ってきた EMPLOYEE_CD があれば Lookup して反映
    document.addEventListener("DOMContentLoaded", async () => {
        restoreFormState();
        if (qrInput && typeof qrInput.focus === "function") {
            try { qrInput.focus(); } catch (e) {}
        }
        if (selectedCooperateCd) {
            try {
                const res = await fetch('@Url.Action("LookupCooperate", "Scan")' + `?cooperateCd=${encodeURIComponent(selectedCooperateCd)}`);
                const data = await res.json();
                if (data && data.ok) {
                    if (companyCdEl) companyCdEl.value = data.cooperateCd ?? selectedCooperateCd;
                    if (companyKanaEl) companyKanaEl.value = data.companyKana ?? "";
                    if (companyNameEl) companyNameEl.value = data.companyName ?? "";
                }
            } catch (ex) {}
        }
        if (!selectedEmployeeCd) return;

        try {
            currentQrPrefix = "1"; // 検索選択は通常扱いにする（必要なら調整）

            const res = await fetch('@Url.Action("Lookup", "Scan")', {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ code: selectedEmployeeCd, prefix: "1" })
            });

            const data = await res.json();

            if (!data || data.ok !== true) {
                setIcon("NG");
                playBeep("NG");
                appendLog(`${selectedEmployeeCd} ${data?.message ?? "Lookup failed"}`);
                return;
            }

            clearLookupFields(); // 追加: 新しいデータ適用前にフィールドクリア
            if (input) input.value = data.code ?? selectedEmployeeCd;
            if (companyCdEl) companyCdEl.value = data.cooperateCd ?? "";
            if (companyKanaEl) companyKanaEl.value = data.companyKana ?? "";
            if (companyNameEl) companyNameEl.value = data.companyName ?? "";

            setInputLock(true);

            if (workerFamilyKanaEl) workerFamilyKanaEl.value = data.workerFamilyKana ?? "";
            if (workerFirstKanaEl) workerFirstKanaEl.value = data.workerFirstKana ?? "";
            if (workerFamilyNameEl) workerFamilyNameEl.value = data.workerFamilyName ?? "";
            if (workerFirstNameEl) workerFirstNameEl.value = data.workerFirstName ?? "";

            if (birthDateEl && data.birthYmd) {
                const by = String(data.birthYmd || "");
                if (by.length === 8) birthDateEl.value = `${by.substring(0, 4)}/${by.substring(4, 6)}/${by.substring(6, 8)}`;
            }

            // 除外日を表示（サーバ側で既にフォーマット済み）
            if (excludeDateEl) {
                excludeDateEl.value = data.excludeDate ?? "";
            }

            // 既存の入退場時刻を反映
            try {
                const et = data.entryTime || "";
                const xt = data.exitTime || "";
                if (et && entryRecordEl) entryRecordEl.value = (et.length >= 4) ? (et.slice(0,2) + ":" + et.slice(2,4)) : et;
                if (xt && exitRecordEl) exitRecordEl.value = (xt.length >= 4) ? (xt.slice(0,2) + ":" + xt.slice(2,4)) : xt;
            } catch (ex) {}

            const displayName =
                (data.workerFamilyName || "") + (data.workerFirstName ? (" " + data.workerFirstName) : "") ||
                (data.workerName ?? (data.workerKana ?? ""));

            let timeToShow = "";
            try {
                if (data.entryTime) timeToShow = (data.entryTime.length >= 4) ? (data.entryTime.slice(0,2) + ":" + data.entryTime.slice(2,4)) : data.entryTime;
                else if (data.exitTime) timeToShow = (data.exitTime.length >= 4) ? (data.exitTime.slice(0,2) + ":" + data.exitTime.slice(2,4)) : data.exitTime;
            } catch (ex) { timeToShow = ""; }

            showReadResult(data.code ?? selectedEmployeeCd, displayName, timeToShow);
            setIcon("OK");
            playBeep("OK");
            appendLog(`${data.code ?? selectedEmployeeCd} ${displayName} 取得OK`);
        } catch (ex) {
            setIcon("NG");
            playBeep("NG");
            appendLog(`ERR ${ex}`);
        }
    });

    const btnWorkerSearch = document.getElementById("btnWorkerSearch");
    if (btnWorkerSearch) {
        btnWorkerSearch.addEventListener("click", function () {
            saveFormState();
            window.location.href =
                '@Url.Action("Index", "EmployeeSearch", new { returnUrl = Url.Action("TempInput", "Scan", new { kind = kind }) })';
        });
    }

    if (btnCompanySearch) {
        btnCompanySearch.addEventListener("click", function () {
            saveFormState();
            window.location.href =
                '@Url.Action("Index", "CooperateSearch", new { returnUrl = Url.Action("TempInput", "Scan", new { kind = kind }) })';
        });
    }

    if (btnBackToEventSelection) {
        btnBackToEventSelection.addEventListener("click", function () {
            sessionStorage.removeItem(formStateKey);
        });
    }

    // 追加: readonly フィールドのクリック時はQR入力へフォーカス
    const readonlyFocusTargets = [
        input,
        companyCdEl,
        companyKanaEl,
        companyNameEl,
        excludeDateEl,
        workerFamilyKanaEl,
        workerFirstKanaEl,
        workerFamilyNameEl,
        workerFirstNameEl,
        birthDateEl,
        logArea
    ];
    readonlyFocusTargets.forEach(el => {
         if (!el) return;
         el.addEventListener("click", () => {
            if (el.readOnly && qrInput && typeof qrInput.focus === "function") {
                 try { qrInput.focus(); } catch (e) {}
             }
         });
     });
</script>

</body>
</html>
