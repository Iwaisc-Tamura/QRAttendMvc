@model IEnumerable<QRAttendMvc.Controllers.CooperateSearchController.CooperateSearchRow>

@{
    Layout = null;
    ViewData["Title"] = "会社検索";

    string companyKana = Context.Request.Query["companyKana"].ToString();
    string returnUrl = Context.Request.Query["returnUrl"].ToString();

    string login = ViewBag.LoginText as string ?? "";

    var currentSort = Context.Request.Query["sort"].ToString();
    var currentDir = Context.Request.Query["dir"].ToString(); // "asc" or "desc"

    bool hasSearched =
    Context.Request.Query.ContainsKey("searched") &&
    !string.IsNullOrWhiteSpace(Context.Request.Query["searched"]);

    var resultCount = (int)(ViewBag.ResultCount ?? 0);
}

<!doctype html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="index-cooprete">

    <header class="es-header">
        <div class="es-tab">検索</div>
        <div class="es-title">会社検索</div>
    </header>




    <main class="es-container">
        <div class="ee-top">
            <div>
                <form method="get" class="es-form" id="searchForm" onsubmit="document.getElementById('isSearchButton').value='1';">
                    <input type="hidden" name="searched" value="true" />
                    <input type="hidden" name="sort" value="@currentSort" />
                    <input type="hidden" name="dir" value="@currentDir" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <input type="hidden" name="isSearchButton" id="isSearchButton" value="" />

                    <div class="es-grid es-grid-1">
                        <div class="es-field es-span2">
                            <label class="es-label">会社名（カナ）</label>
                            <input name="companyKana" value="@companyKana" class="es-input" />
                        </div>

                        <div class="es-field es-action">
                            <button type="submit" class="es-btn es-btn-search"
                                    onclick="document.getElementById('isSearchButton').value='1'">
                                検索
                            </button>
                        </div>

                        <div class="es-field es-action">
                            <a asp-action="Index"
                               asp-route-returnUrl="@returnUrl"
                               class="es-btn es-btn-search">クリア</a>
                        </div>
                    </div>
                </form>
            </div>

            <!-- ログイン情報 -->
            <div class="ee-side">
                <div class="ee-login" aria-label="ログイン情報">
                    <div class="ev-login-row">
                        <span class="ev-login-label">ログイン</span>
                        <span class="ev-login-value">@login</span>
                    </div>
                    <div class="ev-login-row">
                        <span class="ev-login-label">日付</span>
                        <span class="ev-login-value" id="layoutDate"></span>
                    </div>
                    <div class="ev-login-row">
                        <span class="ev-login-label">時刻</span>
                        <span class="ev-login-value" id="layoutTime"></span>
                    </div>
                </div>
            </div>
        </div>

             @if (!hasSearched)
            {
                <div class="es-hint">
                    検索条件を入力して「検索」を押してください。（未入力のまま検索すると全件表示します）
                </div>
            }
            else
            {
                <div class="es-hint" style="text-align:right; font-weight:700;">
                    @if (resultCount > 0)
                    {
                        <text>対象件数：@resultCount.ToString("#,0")</text>
                    }
                    else
                    {
                        <text>対象ありません。</text>
                    }
                </div>
            }

        <section class="es-tablewrap">
            <table class="es-table">
                <thead>
                    <tr>
                        <th>
                            <a asp-action="Index" asp-all-route-data="@(RouteFor("cooperatecd"))">
                                協力会社コード@(Arrow("cooperatecd"))
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-all-route-data="@(RouteFor("companyname"))">
                                会社名@(Arrow("companyname"))
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-all-route-data="@(RouteFor("companykana"))">
                                会社名カナ@(Arrow("companykana"))
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-all-route-data="@(RouteFor("address"))">
                                住所@(Arrow("address"))
                            </a>
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr class="es-row"
                            data-cd="@r.CooperateCd"
                            onclick="selectCooperate(this)">
                            <td>@r.CooperateCd</td>
                            <td>@r.CompanyName</td>
                            <td>@r.CompanyNameKana</td>
                            <td>@r.Address</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <section class="es-footer">

            <!-- 選択確定フォーム -->
            <form method="post" asp-action="Back" id="selectForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <input type="hidden" name="selectedCooperateCd" id="selectedCooperateCd" value="" />
                <button type="button" class="es-btn es-btn-search" onclick="commitSelect()">選択</button>
            </form>

            <!-- 単純戻る -->
            <button type="button" class="es-btn es-btn-back" onclick="goBack()">入退場登録画面<br />に戻る</button>

        </section>

    </main>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const now = new Date();

            const week = ["日", "月", "火", "水", "木", "金", "土"];
            const w = week[now.getDay()];

            // yyyy/MM/dd（曜日）
            const dateText =
                now.getFullYear() + "/" +
                String(now.getMonth() + 1).padStart(2, "0") + "/" +
                String(now.getDate()).padStart(2, "0") +
                "（" + w + "）";

            // HH:mm:ss
            const timeText =
                String(now.getHours()).padStart(2, "0") + ":" +
                String(now.getMinutes()).padStart(2, "0") + ":" +
                String(now.getSeconds()).padStart(2, "0");

            document.getElementById("layoutDate").textContent = dateText;
            document.getElementById("layoutTime").textContent = timeText;
        });

        // Enterで検索
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("searchForm");
            form?.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    const tag = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : "";
                    if (tag === "textarea") return;

                    e.preventDefault();
                    form.requestSubmit();
                }
            });
        });

        function selectCooperate(tr) {
            const cd = tr?.getAttribute("data-cd") || "";

            document.getElementById("selectedCooperateCd").value = cd;

            document.querySelectorAll("tr.es-row").forEach(x => x.classList.remove("es-selected"));
            if (tr) tr.classList.add("es-selected");
        }

        function commitSelect() {
            const cd = document.getElementById("selectedCooperateCd").value;
            if (!cd) {
                alert("一覧から会社を選択してください。");
                return;
            }
            document.getElementById("selectForm").submit();
        }

        function goBack() {
            const ru = "@returnUrl";
            if (ru) {
                window.location.href = ru;
                return;
            }
            history.back();
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll("tr.es-row").forEach(tr => {
                tr.addEventListener("dblclick", function () {
                    selectCooperate(tr);  
                    commitSelect();
                });
            });
        });
    </script>

    @if (hasSearched && resultCount == 0)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                alert("検索対象がありませんでした。");
            });
        </script>
    }

    @functions {

        public string NextDir(string key)
        {
            var currentSort = Context.Request.Query["sort"].ToString();
            var currentDir = Context.Request.Query["dir"].ToString();

            if (string.Equals(currentSort, key, StringComparison.OrdinalIgnoreCase))
                return string.Equals(currentDir, "desc", StringComparison.OrdinalIgnoreCase)
                ? "asc"
                : "desc";

            return "asc";
        }

        public string Arrow(string key)
        {
            var currentSort = Context.Request.Query["sort"].ToString();
            var currentDir = Context.Request.Query["dir"].ToString();

            if (!string.Equals(currentSort, key, StringComparison.OrdinalIgnoreCase))
                return "";

            return string.Equals(currentDir, "desc", StringComparison.OrdinalIgnoreCase)
            ? " ▲"
            : " ▼";
        }

        public Dictionary<string, string> RouteFor(string key)
        {
            var dict = Context.Request.Query.ToDictionary(
            k => k.Key,
            v => v.Value.ToString()
            );

            dict["sort"] = key;
            dict["dir"] = NextDir(key);
            dict["searched"] = "true";

            // ★ ここを直接取得に変更
            var ru = Context.Request.Query["returnUrl"].ToString();
            var kana = Context.Request.Query["companyKana"].ToString();

            dict["returnUrl"] = ru ?? "";
            dict["companyKana"] = kana ?? "";

            return dict;
        }
    }

</body>
</html>