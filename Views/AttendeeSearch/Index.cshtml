@model IEnumerable<QRAttendMvc.Models.AttendeeSearchRow>
@using QRAttendMvc.Models
@using System.Globalization

@{
    Layout = null; 
    ViewData["Title"] = "入退場照会";

    string currentKaisaiCd = ViewBag.CurrentKaisaiCd as string ?? "";

    string companyKana = Context.Request.Query["companyKana"].ToString();
    string companyName = Context.Request.Query["companyName"].ToString();
    string workerKana = Context.Request.Query["workerKana"].ToString(); // 使うなら定義
    string workerName = Context.Request.Query["workerName"].ToString(); // ★不足してたので追加
    string workerId = Context.Request.Query["workerId"].ToString();
    string birthDate = Context.Request.Query["birthDate"].ToString();
    string filter = Context.Request.Query["filter"].ToString();
    if (string.IsNullOrEmpty(filter))
    {
        filter = "1"; // ★デフォルトは@FILTERCONDITION = '1'
    }
    string login = ViewBag.LoginText as string ?? "";

    string includeSecond = Context.Request.Query["includeSecond"].ToString();

    // includeSecond が未指定（初期表示やクリア直後）ならデフォルトON
    bool includeSecondChecked =
        string.IsNullOrEmpty(includeSecond) ||
        includeSecond == "true" ||
        includeSecond == "on";

    bool hasSearched =
    Context.Request.Query.ContainsKey("searched") &&
    !string.IsNullOrWhiteSpace(Context.Request.Query["searched"]);

    var ja = new CultureInfo("ja-JP");
    var serverNow = DateTime.Now; // サーバ現在日時（ページを開いた瞬間）
    var serverDateText = serverNow.ToString("yyyy/MM/dd (ddd)", ja);
    var serverTimeText = serverNow.ToString("hh:mm:ss", ja); // 要望通り hh

    var currentSort = Context.Request.Query["sort"].ToString();
    var currentDir = Context.Request.Query["dir"].ToString(); // "asc" or "desc"

}

<!doctype html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <!-- 単独表示なので自前でCSSを読む -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="index-attende">
    <!-- ===== ヘッダー（master風） ===== -->
    <header class="as-header">
        <div class="as-tab">検索</div>
        <div class="as-title">入退場照会</div>
    </header>

    <main class="as-container">
        <div class="ee-top">

            <div class="as-event-header">
                <div class="as-event-row">
                    <div class="as-ev-label">イベント開催日</div>
                    <div class="as-ev-value">@ViewBag.EventDate</div>
                </div>

                <div class="as-event-row">
                    <div class="as-ev-label">区分</div>
                    <div class="as-ev-value">@ViewBag.Kubun</div>
                </div>

                <div class="as-event-row">
                    <div class="as-ev-label">開催拠点</div>
                    <div class="as-ev-value">@ViewBag.Kyoten</div>
                </div>

                <div class="as-event-row">
                    <div class="as-ev-label">講習場所</div>
                    <div class="as-ev-value">@ViewBag.Place</div>
                </div>

                <div class="as-event-row as-event-row-time">
                    <div class="as-ev-label">開催時刻</div>
                    <div class="as-ev-value">@ViewBag.StartTime ～ @ViewBag.EndTime</div>

                    <div class="as-ev-label as-ev-label-inline">受付開始時刻</div>
                    <div class="as-ev-value as-ev-value-inline">@ViewBag.Uketsuke</div>

                    <div class="as-ev-label as-ev-label-inline">開催コード</div>
                    <div class="as-ev-value as-ev-value-inline">@currentKaisaiCd</div>
                </div>

            </div>
            <!-- ログイン情報 -->
            <div class="ee-side">
                <div class="ee-login" aria-label="ログイン情報">
                    <div class="ev-login-row">
                        <span class="ev-login-label">ログイン</span>
                        <span class="ev-login-value">@login</span>
                    </div>
                    <div class="ev-login-row">
                        <span class="ev-login-label">日付</span>
                        <span class="ev-login-value" id="layoutDate">@serverDateText</span>
                    </div>
                    <div class="ev-login-row">
                        <span class="ev-login-label">時刻</span>
                        <span class="ev-login-value" id="layoutTime">@serverTimeText</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- ===== 検索条件 ===== -->
        <form method="get" class="as-form" id="searchForm">

            <!-- 追加 2026.02.17 Takada ：検索ボタンを押したかどうか -->
            <input type="hidden" name="searched" value="true" />

            <!-- 追加 2026.02.17 Takada ：ソート結果を残す -->
            <input type="hidden" name="sort" value="@currentSort" />
            <input type="hidden" name="dir" value="@currentDir" />

            <!-- 1段目：会社名（カナ）／会社名／2次店以下含む／検索 -->
            <div class="as-grid as-grid-1">
                <div class="as-field">
                    <label class="as-label">会社名（カナ）</label>
                    <input name="companyKana" value="@companyKana" class="as-input" />
                </div>

                <div class="as-field">
                    <label class="as-label">会社名</label>
                    <input name="companyName" value="@companyName" class="as-input" />
                </div>

                <div class="as-field as-check">
                    <label class="as-checkline">
                        <input type="checkbox" name="includeSecond" value="true" @(includeSecondChecked ? "checked" : "") />
                        2次店以下を含む
                    </label>
                </div>

                <div class="as-field as-action">
                    <button type="submit" class="as-btn as-btn-search">検索</button>
                </div>


                <div class="as-field as-action">
                    <a asp-action="Index" class="as-btn as-btn-search">クリア</a>
                </div>

            </div>

            <!-- 2段目：作業員名（カナ）姓／名／作業員ID／生年月日 -->
            <div class="as-grid as-grid-2">
                <div class="as-field">
                    <label class="as-label">作業員名（カナ）</label>
                    <input name="workerKana" value="@workerKana" class="as-input" />
                </div>

                <div class="as-field">
                    <label class="as-label">作業員名</label>
                    <input name="workerName" value="@workerName" class="as-input" />
                </div>

                <div class="as-field">
                    <label class="as-label">作業員ID</label>
                    <input name="workerId" value="@workerId" class="as-input" />
                </div>

                <div class="as-field">
                    <label class="as-label">生年月日</label>
                    <input name="birthDate" id="birthDate" type="text" inputmode="numeric" placeholder="yyyy/mm/dd"
                           value="@birthDate" class="as-input as-birth" autocomplete="off" />
                </div>
                <div class="as-field">
                    <label class="as-label">絞り込み条件</label>
                    <select name="filter" class="as-input">
                        <option value="1" selected="@(filter=="1")">入場のみ、又は入退場記録あり</option>
                        <option value="2" selected="@(filter=="2")">入場・退場記録あり</option>
                        <option value="3" selected="@(filter=="3")">入場記録のみあり（退場記録なし）</option>
                        <option value="4" selected="@(filter=="4")">従業員情報マスタに登録あり</option>
                    </select>
                </div>
            </div>
        </form>


        @if (!hasSearched)
        {
            <div class="as-hint">
                検索条件を入力して「検索」を押してください。（未入力のまま検索すると全件表示します）
            </div>
        }
        else
        {
            <div class="as-hint as-hint-right">
                @{
                    var count = (int)(ViewBag.ResultCount ?? 0);
                }

                @if (count > 0)
                {
                    <text>対象件数：@count.ToString("#,0")</text>
                }
                else
                {
                    <text>対象ありません。</text>
                }
            </div>
        }
        <!-- ===== 一覧 ===== -->
        <section class="as-tablewrap">
            <table class="as-table">
                <thead>
                    <tr>
                        <th>
                            <a asp-action="Index"
                            asp-all-route-data="@(RouteFor("company"))">
                                会社名@(Arrow("company"))
                            </a>
                        </th>

                        <th>
                            <a asp-action="Index"
                            asp-all-route-data="@(RouteFor("workerid"))">
                                作業員ID@(Arrow("workerid"))
                            </a>
                        </th>

                        <th>
                            <a asp-action="Index"
                            asp-all-route-data="@(RouteFor("workername"))">
                                作業員名@(Arrow("workername"))
                            </a>
                        </th>

                        <th>
                            <a asp-action="Index"
                            asp-all-route-data="@(RouteFor("birth"))">
                                生年月日@(Arrow("birth"))
                            </a>
                        </th>

                        <th>
                            <a asp-action="Index"
                            asp-all-route-data="@(RouteFor("exclude"))">
                                名簿対象除外日@(Arrow("exclude"))
                            </a>
                        </th>

                        <th>
                            <a asp-action="Index" asp-all-route-data="@(RouteFor("lastin"))">
                                入場記録@(Arrow("lastin"))
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-all-route-data="@(RouteFor("lastout"))">
                                退場記録@(Arrow("lastout"))
                            </a>
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.CompanyName</td>
                            <td>@r.WorkerId</td>
                            <td>@r.WorkerName</td>

                            <td>@r.BirthDate</td>
                            <td>@r.ExcludeDate</td>
                            <td>@r.LastInTime</td>
                            <td>@r.LastOutTime</td>

                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <!-- ===== 操作ボタン ===== -->
        <section class="as-footer">
            @if (hasSearched)
            {
                <a asp-action="Export"
                   asp-all-route-data="@(Context.Request.Query.ToDictionary(
                k => k.Key,
                v => v.Value.ToString()))"
                   class="as-btn as-btn-primary">
                    CSV出力<br>（タブ区切り）
                </a>
            }
            else
            {
                <span class="as-btn as-btn-primary as-btn-disabled" aria-disabled="true">
                    CSV出力<br>（タブ区切り）
                </span>
            }

            <a asp-controller="EventSelection" asp-action="Index" class="as-btn as-btn-secondary">
                イベント選択<br>画面に戻る
            </a>
        </section>

    </main>

    <!-- ★② 指定スクリプト（そのまま） -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const birthDateEl = document.getElementById("birthDate");

            function formatToDisplayYmd(raw) {
                if (!raw) return "";
                const digits = String(raw).replace(/[^\d]/g, "");
                if (digits.length === 8) {
                    return digits.substring(0, 4) + "/" + digits.substring(4, 6) + "/" + digits.substring(6, 8);
                }
                const m = String(raw).match(/^(\d{4})[-\/](\d{2})[-\/](\d{2})$/);
                if (m) return `${m[1]}/${m[2]}/${m[3]}`;
                return String(raw);
            }

            if (birthDateEl) {
                birthDateEl.addEventListener('input', () => {
                    const v = birthDateEl.value || "";
                    const onlyDigits = v.replace(/[^\d]/g, "");
                    if (onlyDigits.length === 8) {
                        birthDateEl.value = formatToDisplayYmd(onlyDigits);
                    }
                });

                birthDateEl.addEventListener('blur', () => {
                    const v = (birthDateEl.value || "").trim();
                    birthDateEl.value = formatToDisplayYmd(v);
                });
            }
        });



        document.addEventListener("DOMContentLoaded", function () {
            // （既存：日付・時刻の表示 …）

            // Enterで検索（textareaは除外）
            const form = document.getElementById("searchForm");
            form?.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    const tag = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : "";
                    if (tag === "textarea") return;

                    e.preventDefault();   // 変な改行や二重送信防止
                    form.requestSubmit(); // submitボタン経由で送信（hiddenも送られる）
                }
            });
        });



     </script>

    @if (hasSearched && (ViewBag.NoResult ?? false))
    {
        <text>
            <script>
                window.addEventListener("DOMContentLoaded", function () {
                    alert("検索対象がありませんでした。");
                });
            </script>
        </text>
    }

    @functions {

        public string NextDir(string key)
        {
            var currentSort = Context.Request.Query["sort"].ToString();
            var currentDir = Context.Request.Query["dir"].ToString();

            if (string.Equals(currentSort, key, StringComparison.OrdinalIgnoreCase))
                return string.Equals(currentDir, "desc", StringComparison.OrdinalIgnoreCase)
                    ? "asc"
                    : "desc";

            return "asc";
        }

        public string Arrow(string key)
        {
            var currentSort = Context.Request.Query["sort"].ToString();
            var currentDir = Context.Request.Query["dir"].ToString();

            if (!string.Equals(currentSort, key, StringComparison.OrdinalIgnoreCase))
                return "";

            return string.Equals(currentDir, "desc", StringComparison.OrdinalIgnoreCase)
                ? " ▼"
                : " ▲";
        }

        public Dictionary<string, string> RouteFor(string key)
        {
            var dict = Context.Request.Query.ToDictionary(
                k => k.Key,
                v => v.Value.ToString()
            );

            dict["sort"] = key;
            dict["dir"] = NextDir(key);
            dict["searched"] = "true";

            return dict;
        }

    }

</body>
</html>